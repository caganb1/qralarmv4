<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <!--
      Typography: "Nunito" via Android Downloadable Fonts.
      See res/font/ — no APK size increase; font downloads on first run.
      Fallback: sans-serif-medium (always available, feels similar).
    -->

    <style name="Theme.QRAlarm" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/accent</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="android:colorBackground">@color/background</item>
        <item name="colorSurface">@color/surface</item>
        <item name="android:statusBarColor">@color/black</item>
        <item name="android:navigationBarColor">@color/black</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>

        <!-- Global font: Nunito if downloaded, else sans-serif-medium -->
        <item name="android:fontFamily">@font/nunito</item>
        <item name="fontFamily">@font/nunito</item>

        <!-- Globally rounded buttons and cards (Material 3 shape system) -->
        <item name="shapeAppearanceSmallComponent">@style/ShapeSmall</item>
        <item name="shapeAppearanceMediumComponent">@style/ShapeMedium</item>
        <item name="shapeAppearanceLargeComponent">@style/ShapeLarge</item>
    </style>

    <style name="Theme.QRAlarm.Fullscreen" parent="Theme.QRAlarm">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowBackground">@color/background</item>
    </style>

    <!-- ── Shape tokens ─────────────────────────────────────────────────── -->
    <style name="ShapeSmall" parent="ShapeAppearance.Material3.SmallComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">16dp</item>
    </style>
    <style name="ShapeMedium" parent="ShapeAppearance.Material3.MediumComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">24dp</item>
    </style>
    <style name="ShapeLarge" parent="ShapeAppearance.Material3.LargeComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">28dp</item>
    </style>

    <!-- Square FAB for Bauhaus look -->
    <style name="ShapeSquareFab">
        <item name="cornerFamily">cut</item>
        <item name="cornerSize">0%</item>
    </style>

    <!-- Day checkboxes: circle toggles, Nunito font -->
    <style name="DayCheckbox">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">40dp</item>
        <item name="android:layout_weight">1</item>
        <item name="android:button">@null</item>
        <item name="android:background">@drawable/bg_day_checkbox</item>
        <item name="android:gravity">center</item>
        <item name="android:layout_margin">3dp</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@drawable/text_day_checkbox</item>
        <item name="android:fontFamily">@font/nunito</item>
    </style>
</resources>
